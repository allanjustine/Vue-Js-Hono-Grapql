  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.32",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "hono": "^4.12.14",
    "postgres": "^3.4.9"
  }
}
